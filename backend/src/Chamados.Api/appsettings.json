{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Key": "",
    "Issuer": "",
    "Audience": "",
    "ExpiresMinutes": 60
  },
  "SlaMonitor": {
    "IntervalSeconds": 300
  },
  "Upload": {
    "StoragePath": "uploads",
    "MaxFileSizeBytes": 104857600,
    "AllowedExtensions": [
      ".jpg", ".jpeg", ".png", ".gif", ".webp",
      ".pdf", ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx", ".txt", ".csv",
      ".mp4", ".mov", ".avi", ".webm", ".mkv"
    ]
  }
}
