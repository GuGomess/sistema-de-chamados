# ============================================================
# Variáveis de ambiente do Sistema de Chamados
# Copie para .env e ajuste os valores. NÃO versione o .env real.
#   cp .env.example .env
# ============================================================

# ----- PostgreSQL (usado pelo docker-compose) -----
POSTGRES_DB=chamados
POSTGRES_USER=chamados
POSTGRES_PASSWORD=troque-esta-senha
# Porta exposta no host (container sempre usa 5432 internamente)
DB_PORT=5432

# ----- Connection string de referência p/ o backend ASP.NET Core -----
# Consumida via configuração (ex.: ConnectionStrings__DefaultConnection).
# Host = "db" quando o backend roda no mesmo docker-compose;
# use "localhost" ao rodar o backend fora do Docker.
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=chamados;Username=chamados;Password=troque-esta-senha
