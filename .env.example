# ============================================================
# Variáveis de ambiente do Sistema de Chamados
# Copie para .env e ajuste os valores. NÃO versione o .env real.
#   cp .env.example .env
# ============================================================

# ----- PostgreSQL (usado pelo docker-compose) -----
POSTGRES_DB=chamados
POSTGRES_USER=chamados
POSTGRES_PASSWORD=troque-esta-senha
# Porta exposta no host (container sempre usa 5432 internamente)
DB_PORT=5432

# ----- Connection string de referência p/ o backend ASP.NET Core -----
# Consumida via configuração (ex.: ConnectionStrings__DefaultConnection).
# Host = "db" quando o backend roda no mesmo docker-compose;
# use "localhost" ao rodar o backend fora do Docker.
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=chamados;Username=chamados;Password=troque-esta-senha

# ----- Backend (ASP.NET Core, usado pelo docker-compose) -----
# Porta exposta no host (container sempre usa 8080 internamente).
API_PORT=5000
# Development habilita Swagger UI em /swagger.
ASPNETCORE_ENVIRONMENT=Development

# ----- JWT (autenticação — a integrar na Fase 2: Endpoint de login + JWT) -----
# Chave secreta usada para assinar os tokens. Use um valor longo e aleatório em produção.
Jwt__Key=troque-esta-chave-secreta-com-no-minimo-32-caracteres
Jwt__Issuer=SistemaChamados
Jwt__Audience=SistemaChamados
# Tempo de expiração do token de acesso, em minutos.
Jwt__ExpiresMinutes=60

# ----- Frontend (Angular/nginx, usado pelo docker-compose) -----
# Porta exposta no host (container sempre usa 80 internamente).
WEB_PORT=4200

# ----- Upload de anexos (backend) -----
# Tamanho máximo por arquivo, em bytes (padrão: 100 MiB). O caminho de
# armazenamento (Upload__StoragePath) já é fixado em /app/uploads pelo
# docker-compose, apontando para o volume nomeado "uploads-data".
Upload__MaxFileSizeBytes=104857600
